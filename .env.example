# Use this for any Postgres-compatible database.
# Works with local PostgreSQL, hosted PostgreSQL, and Supabase Postgres.
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db

# Optional SSL toggle for hosted providers.
DB_SSL=false

# API server port.
PORT=3000

# Optional tester numbers for forced rewards and reset.
TESTER_MOBILE_NUMBERS=9500365660,9600692495

# Transfer mode:
# - mock: local success without external provider
# - provider: tries Redash lookup + Dostt upload if keys are set
TRANSFER_MODE=mock
#provider
# Optional external transfer integration.
REDASH_API_KEY=
REDASH_QUERY_ID=
DOSTT_AUTH_KEY=
SLACK_WEBHOOK_URL=
